// apps/api/prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" 
}

model Usuario {
  id              Int              @id @default(autoincrement())
  idInstituicao   Int?
  nome            String
  cpf             String
  email           String           @unique
  senha           String
  avatarUrl       String?
  role            Role             @default(USER)
  sinaisPropostos SinalProposto[]  @relation("SinaisPropostos")
  sinaisAvaliados SinalProposto[]  @relation("SinaisAvaliados")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt()

  instituicao     Instituicao?     @relation(fields: [idInstituicao], references: [id])
  
  sinaisSalvos    SinalSalvo[]
  curtidas        SinalCurtido[]
  comentarios     Comentario[]

  solicitacoesInstituicao SolicitacaoInstituicao[]
  solicitacoesVinculo     SolicitacaoVinculo[]
} 

enum Role {
  USER
  AVALIADOR
  ADMIN
}

model Instituicao {
  id                 Int      @id @default(autoincrement())
  nome               String   @unique
  sigla              String
  cidade             String
  estado             String
  nomeRepresentante  String
  cargoRepresentante String
  usuarios           Usuario[]
  createdAt          DateTime @default(now())

  solicitacoesVinculo SolicitacaoVinculo[]
}

model AreaConhecimento {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  cursos    Curso[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model Curso {
  id                Int                @id @default(autoincrement())
  nome              String             @unique
  disciplinas       Disciplina[]
  areasConhecimento AreaConhecimento[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt()
}

model Disciplina {
  id              Int             @id @default(autoincrement())
  idCurso         Int
  nome            String          @unique
  cargaHoraria    String
  sinais          Sinal[]
  sinaisPropostos SinalProposto[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt()

  curso           Curso           @relation(fields: [idCurso], references: [id])
}

model Sinal {
  id              Int         @id @default(autoincrement())
  sinalPropostoId Int         @unique
  disciplinaId    Int
  nome            String      @unique
  descricao       String
  youtubeUrl      String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  disciplina      Disciplina    @relation(fields: [disciplinaId], references: [id])
  sinalProposto   SinalProposto @relation(fields: [sinalPropostoId], references: [id])

  sinaisSalvos    SinalSalvo[]
  curtidas        SinalCurtido[]
  comentarios     Comentario[]
}

// --- CORREÇÃO AQUI ---
enum PropostaStatus {
  PENDENTE
  APROVADO // Corrigido de "APROVado" para "APROVADO"
  REJEITADO
}

model SinalProposto {
  id                   Int            @id @default(autoincrement())
  disciplinaId         Int
  proposerId           Int
  avaliadorId          Int?
  nome                 String         @unique
  descricao            String
  videoBrutoUrl        String
  comentariosAvaliador String?
  status               PropostaStatus @default(PENDENTE)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt 

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  proposer   Usuario    @relation("SinaisPropostos", fields: [proposerId], references:[id])
  avaliador  Usuario?   @relation("SinaisAvaliados", fields: [avaliadorId], references:[id])
  
  Sinal      Sinal?
}

model SinalSalvo {
  usuarioId Int
  sinalId   Int
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sinal   Sinal   @relation(fields: [sinalId],  references: [id], onDelete: Cascade)

  @@id([usuarioId, sinalId])
}

model SinalCurtido {
  usuarioId Int
  sinalId   Int
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sinal   Sinal   @relation(fields: [sinalId],  references: [id], onDelete: Cascade)

  @@id([usuarioId, sinalId])
}

model Comentario {
  id        Int      @id @default(autoincrement())
  texto     String
  createdAt DateTime @default(now())

  sinalId   Int
  usuarioId Int

  sinal   Sinal   @relation(fields: [sinalId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([sinalId])
}


enum SolicitacaoStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

model SolicitacaoInstituicao {
  id                                  Int               @id @default(autoincrement())
  usuarioId                           Int
  nomeInstituicao                     String
  cidade                              String
  estado                              String
  nomeRepresentante                   String
  cargoRepresentante                  String
  documentoComprovativoUsuarioUrl     String
  documentoComprovativoRepresentanteUrl String
  status                              SolicitacaoStatus @default(PENDENTE)
  adminFeedback                       String?
  createdAt                           DateTime          @default(now())
  updatedAt                           DateTime          @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model SolicitacaoVinculo {
  id                        Int               @id @default(autoincrement())
  usuarioId                 Int
  instituicaoId             Int
  documentoComprovativoUrl  String
  status                    SolicitacaoStatus @default(PENDENTE)
  adminFeedback             String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  instituicao Instituicao @relation(fields: [instituicaoId], references: [id])
}